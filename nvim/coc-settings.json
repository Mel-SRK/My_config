{
  "snippets.ultisnips.pythonPrompt": false,
  "python.pythonPath": "/usr/bin/python3",
  "python.analysis.completeFunctionParens": true,
  "python.analysis.autoSearchPaths": true,
  "python.analysis.useLibraryCodeForTypes": true,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.diagnosticMode": "openFilesOnly",
  "python.analysis.typeCheckingMode": "off",
  "python.analysis.diagnosticSeverityOverrides": {
    "reportUnusedImport": "none",
    "reportUnusedVariable": "none",
    "reportUnusedClass": "none",
    "reportUnusedFunction": "none"
  },
  "python.analysis.autoFormatStrings": true,
  "coc.preferences.formatOnSave": false,
  "coc.preferences.formatOnType": true,
  "suggest.noselect": false,
  "suggest.enablePreview": true,
  "suggest.triggerAfterInsertEnter": true,
  "suggest.timeout": 3000,
  "suggest.triggerCompletionWait": 200,
  "suggest.autoTrigger": "always",
  "suggest.enablePreselect": true,
  "suggest.detailField": "preview",
  "suggest.snippetIndicator": " ~",
  "suggest.acceptSuggestionOnCommitCharacter": true,
  "diagnostic.errorSign": "✖",
  "diagnostic.warningSign": "⚠",
  "diagnostic.infoSign": "ℹ",
  "diagnostic.hintSign": "➤",
  "coc.source.around.enable": true,
  "coc.source.buffer.enable": true,
  "coc.source.file.enable": true,
  "coc.source.omni.enable": true,
  "coc.source.unicode.enable": true,
  "coc.source.word.enable": true,
  "coc.source.vim.enable": true,
  "coc.source.syntax.enable": true,
  "suggest.languageSourcePriority": 99,
  "suggest.completionItemKindLabels": {
    "variable": "V",
    "function": "F",
    "method": "M",
    "class": "C",
    "interface": "I",
    "module": "M",
    "property": "P",
    "value": "v",
    "enum": "E",
    "keyword": "K",
    "snippet": "S",
    "color": "C",
    "file": "F",
    "folder": "F",
    "enumMember": "E",
    "constant": "C",
    "struct": "S",
    "event": "E",
    "operator": "O",
    "typeParameter": "T"
  }
}
