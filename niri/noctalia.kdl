layout {

    focus-ring {
        active-color   "#e4c54a"
        inactive-color "#15130e"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#e4c54a"
        inactive-color "#15130e"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#e4c54a"
        inactive-color "#554600"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#e4c54a80"
    }
}

recent-windows {
    highlight {
        active-color "#e4c54a"
        urgent-color "#ffb4ab"
    }
}
